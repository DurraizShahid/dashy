# Hive Mind Environment Variables
# Copy to .env and fill in real values.

# Core
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
HIVEMIND_API_KEY=
PUBLIC_BASE_URL=http://localhost:8080

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/hivemind

# Redis
REDIS_URL=redis://default:password@localhost:6379/2

# Vector DB
QDRANT_URL=http://localhost:6333

# Object Storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=hivemind-raw

# Graph DB
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Knowledge Graph Builder
GRAPHITI_URL=http://localhost:8000

# Document Services
DOCLING_URL=http://localhost:5001
CRAWL4AI_URL=http://localhost:11235
ARCHIVEBOX_URL=http://localhost:8000

# Application Services
RAGFLOW_URL=http://localhost:80
PAPERLESS_URL=http://localhost:8000
PERPLEXICA_URL=http://localhost:3000
SEARXNG_URL=http://localhost:8080
WORLD_MONITOR_URL=http://localhost:80

# Auth
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ISSUER_URL=
KEYCLOAK_CLIENT_ID=hivemind-api
KEYCLOAK_AUDIENCE=hivemind-api
AUTH_MODE=hybrid

# LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Startup
RUN_MIGRATIONS_ON_STARTUP=false
RUN_SEED_ON_STARTUP=false
