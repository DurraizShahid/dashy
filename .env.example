# Dashy — Environment Variables
# Copy to .env.local and fill in values from Railway project "nervous-system"
#
# ─── Public (inlined at build time, visible to browser) ──────
#
# NEXT_PUBLIC_* vars are used only for client-side URL references.
# No secrets, tokens, or API keys should ever go here.

# Clerk — publishable key (public, safe for browser)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/hive-mind/overview
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/hive-mind/overview

# Canonical app URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000


# ─── Server-Only (never exposed to browser bundle) ──────────

# Clerk — secret key (server-only)
CLERK_SECRET_KEY=

# Server-side Hive Mind API URL (private network on Railway)
# In local dev: https://hivemind-api-production-edd9.up.railway.app
# On Railway: use the private network URL (http://hivemind-api.railway.internal)
HIVE_MIND_API_URL=
