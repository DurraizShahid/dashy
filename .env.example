# Dashy — Environment Variables

# === Hive Mind API ===
# Public URL for development; use private network URL in production
NEXT_PUBLIC_HIVE_MIND_API_URL=http://localhost:8080

# === Authentication (Future — Keycloak) ===
# NEXT_PUBLIC_KEYCLOAK_URL=
# NEXT_PUBLIC_KEYCLOAK_REALM=
# NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=
# KEYCLOAK_CLIENT_SECRET=
# NEXTAUTH_SECRET=

# === Feature Flags ===
# Set to "true" to enable auth-gated features
# NEXT_PUBLIC_AUTH_ENABLED=false

# === HelpTribe CRM (Existing) ===
# DATABASE_URL=
# OPENAI_API_KEY=
# GITHUB_TOKEN=
