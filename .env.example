# Dashy — Environment Variables
# Copy to .env.local and fill in values from Railway project "nervous-system"
#
# ─── Public (inlined at build time, visible to browser) ──────
#
# NEXT_PUBLIC_* vars are used only for client-side URL references.
# No secrets, tokens, or API keys should ever go here.

# Hive Mind API — public URL for client-side reference
# In local dev: https://hivemind-api-production-edd9.up.railway.app
# On Railway: use the private network URL (http://hivemind-api.railway.internal)
NEXT_PUBLIC_HIVEMIND_API_URL=

# Keycloak OIDC provider
NEXT_PUBLIC_KEYCLOAK_URL=
NEXT_PUBLIC_KEYCLOAK_REALM=hivemind
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=hivemind-api

# Canonical app URL (used for OIDC redirect_uri)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── Server-Only (never exposed to browser bundle) ──────────

# Keycloak client secret (confidential client)
KEYCLOAK_CLIENT_SECRET=

# Session encryption key — generate with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes)
SESSION_ENCRYPTION_KEY=

# Server-side Hive Mind API URL (private network on Railway)
# If unset, falls back to NEXT_PUBLIC_HIVEMIND_API_URL
# HIVEMIND_API_URL=http://hivemind-api.railway.internal

# Optional server-only API key for admin/service operations (never in browser)
# HIVEMIND_INTERNAL_API_KEY=
