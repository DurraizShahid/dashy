# Dashy — Environment Variables
# Copy to .env.local and fill in values from Railway project "nervous-system"

# === Hive Mind API ===
# Public URL for local dev; use private network URL (http://hivemind-api.railway.internal) on Railway
NEXT_PUBLIC_HIVE_MIND_API_URL=https://hivemind-api-production-edd9.up.railway.app

# API key for Hive Mind authenticated endpoints (from hivemind-api service env)
NEXT_PUBLIC_HIVE_MIND_API_KEY=

# === Base URL ===
# Canonical public URL for this app. Used for OIDC redirects and post-login redirects.
# Falls back to NEXT_PUBLIC_APP_URL for backward compatibility, then localhost:3000.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# === Keycloak Authentication ===
# Keycloak is deployed on Railway (keycloak-production-15b2.up.railway.app)
NEXT_PUBLIC_KEYCLOAK_URL=https://keycloak-production-15b2.up.railway.app
NEXT_PUBLIC_KEYCLOAK_REALM=hivemind
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=hivemind-api
# KEYCLOAK_CLIENT_SECRET= (server-only, set on Railway)

# === Session ===
# SESSION_ENCRYPTION_KEY= (server-only, used for hm_session JWT signing)

# === HelpTribe CRM (Existing - gitignored, stored in .env) ===
# DATABASE_URL=
# OPENAI_API_KEY=
# GITHUB_TOKEN=
